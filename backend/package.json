{
  "name": "@faberon/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Faberon NestJS backend",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc-watch -p tsconfig.build.json --onSuccess \"node dist/main.js\"",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.json",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "migration:run": "drizzle-kit migrate",
    "migration:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "amqplib": "^2.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "1.0.0-rc.4",
    "joi": "^18.2.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "1.0.0-rc.4",
    "jest": "^30.4.2",
    "tsc-watch": "^7.2.1",
    "typescript": "^7.0.2"
  }
}
