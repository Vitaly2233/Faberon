# Public API base URL (used when mock mode is disabled)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# When true, the app uses in-memory mock services instead of HTTP
EXPO_PUBLIC_USE_MOCKS=true

# Show development-only role switcher on login screen (keep false in production builds)
EXPO_PUBLIC_DEV_ROLE_SWITCHER=false
