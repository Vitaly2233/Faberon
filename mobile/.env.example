# Public API base URL (used when mock mode is disabled)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# When true, the app uses in-memory mock services instead of HTTP
EXPO_PUBLIC_USE_MOCKS=false

# Default company UUID used for POST /auth/login (can also be entered on the login screen)
EXPO_PUBLIC_COMPANY_ID=

# Optional customer UUID for customer-portal sign-in when the backend has no /me endpoint
EXPO_PUBLIC_CUSTOMER_ID=

# Optional product type UUID for creating assets/products via the API
EXPO_PUBLIC_DEFAULT_PRODUCT_TYPE_ID=

# Show development-only role switcher on login screen (always shown in backend mode)
EXPO_PUBLIC_DEV_ROLE_SWITCHER=false
